# =============================================================================
# AIOps platform environment template.
# Copy to `.env` and replace any `<replace-me>` placeholders before running.
# All variables are documented in src/aiops/settings.py.
# =============================================================================

# === Application ===
AIOPS_APP_NAME=aiops
AIOPS_HERMES_INSTANCE=gateway

# === Data Layer ===
AIOPS_DATABASE_URL=postgresql+asyncpg://aiops:aiops@localhost:5432/aiops
AIOPS_REDIS_URL=redis://localhost:6379/0

# === Temporal ===
AIOPS_TEMPORAL_TARGET=localhost:7233
AIOPS_TEMPORAL_NAMESPACE=default
AIOPS_TEMPORAL_TASK_QUEUE=aiops

# === LLM Routing ===
AIOPS_LITELLM_ENDPOINT=http://localhost:4000

# === Langfuse Observability ===
AIOPS_LANGFUSE_HOST=http://localhost:3000
AIOPS_LANGFUSE_PUBLIC_KEY=<replace-me>
AIOPS_LANGFUSE_SECRET_KEY=<replace-me>

# === NetBox CMDB ===
AIOPS_NETBOX_URL=http://localhost:8000
AIOPS_NETBOX_TOKEN=<replace-me>

# === Safety Caps & Kill Switch ===
AIOPS_KILL_SWITCH_KEY_PREFIX=aiops:kill_switch
AIOPS_COST_CAP_USD_PER_INCIDENT=1.0
AIOPS_ACTIVITY_CAP_PER_INCIDENT=50
AIOPS_HERMES_TOOL_CAP_PER_INCIDENT=30
AIOPS_SYNC_AWAIT_TIMEOUT_SEC=60
